# ============================================================
# SECRETS TEMPLATE — Copy to secrets.yaml and fill in real values
# ============================================================
# cp k8s/secrets.yaml.example k8s/secrets.yaml
# Then replace all REPLACE_WITH_REAL_* placeholders.
# Apply manually on the cluster: kubectl apply -f k8s/secrets.yaml
#
# To generate new secrets:
#   JWT:      openssl rand -base64 64
#   CouchDB:  openssl rand -base64 30 | tr -d '/+='
#   Grafana:  openssl rand -base64 40
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: backend-secret
  namespace: money-app
type: Opaque
stringData:
  JWT_SECRET: "REPLACE_WITH_REAL_JWT_SECRET"
  COUCHDB_PASSWORD: "REPLACE_WITH_REAL_COUCHDB_PASSWORD"
---
apiVersion: v1
kind: Secret
metadata:
  name: couchdb-secret
  namespace: money-app
type: Opaque
stringData:
  username: admin
  password: "REPLACE_WITH_REAL_COUCHDB_PASSWORD"
---
apiVersion: v1
kind: Secret
metadata:
  name: grafana-secret
  namespace: money-app
type: Opaque
stringData:
  admin-password: "REPLACE_WITH_REAL_GRAFANA_PASSWORD"

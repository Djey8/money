# Copy this file to .env and fill in real values
# NEVER commit .env to Git
#
# Variables marked REQUIRED must be set for `docker-compose up` to start
# (the compose file uses ${VAR:?...} which fails fast on missing values).

# ─── REQUIRED ──────────────────────────────────────────────────────────

# JWT signing secret (recommend ≥ 32 characters)
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me

# CouchDB admin password
# Generate with: openssl rand -base64 30 | tr -d '/+='
COUCHDB_PASSWORD=change-me

# ─── OPTIONAL (logging overlay) ────────────────────────────────────────

# Grafana admin password (only required when starting docker-compose.logging.yml)
# Generate with: openssl rand -base64 40
GRAFANA_ADMIN_PASSWORD=change-me

# ─── OPTIONAL (backups) ────────────────────────────────────────────────

# Encryption key for backup archives (Kubernetes CronJobs only)
# Generate with: openssl rand -base64 32
# Leave empty or omit to keep backups unencrypted
BACKUP_ENCRYPTION_KEY=

# ─── OPTIONAL (backend tuning — defaults shown) ────────────────────────

# Allowed CORS origins (comma-separated). Default: http://localhost:4200
# CORS_ORIGINS=https://money.example.com

# Backend log verbosity: error | warn | info | debug. Default: warn
# LOG_LEVEL=warn

# Set to "true" to disable IP-based rate limiting (single-user / Pi)
# SKIP_RATE_LIMIT=false
